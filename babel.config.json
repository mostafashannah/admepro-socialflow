{
  "presets": [
    ["@babel/preset-env", {
      "targets": "> 1%, not dead",
      "modules": false
    }],
    ["@babel/preset-react", {
      "runtime": "classic"
    }]
  ],
  "plugins": [
    "@babel/plugin-transform-optional-chaining",
    "@babel/plugin-transform-nullish-coalescing-operator"
  ]
}
