Options -MultiViews
RewriteEngine On

# Public marketing/SEO page — served at the clean URL /features instead of
# /features.html, before the catch-all SPA rewrite below so it doesn't fall
# through to the app.
RewriteRule ^features/?$ features.html [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [QSA,L]

# Uploaded CVs (converted Word docs and originals) should preview inline
# in the browser tab instead of forcing a download — without this, some
# server configs serve .pdf without a proper Content-Type/Disposition
# and browsers fall back to downloading it.
<IfModule mod_mime.c>
  AddType application/pdf .pdf
</IfModule>
<IfModule mod_headers.c>
  <FilesMatch "\.pdf$">
    Header set Content-Disposition inline
  </FilesMatch>
</IfModule>

# ── Compression ── app.js is a large single-file bundle (2MB+ raw); without
# this the browser downloads it uncompressed on every fresh load. Gzip
# shrinks JS/CSS/HTML/JSON text by ~75-80%.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json
</IfModule>

# ── Caching ── app.js/index.html are always requested with a ?v=NNN
# cache-busting query string that changes on every release, so it's safe
# to cache the JS bundle aggressively — a new version gets a new URL.
# index.html itself must NOT be cached, or users get stuck on a stale
# version that keeps requesting an old ?v= of app.js.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
